# Anleitung für das Code Signing von ResidentPrivacyFlow

# 1. Windows Code Signing
# CSC_LINK: Absoluter Pfad zu Ihrer .p12 oder .pfx Zertifikatsdatei.
# CSC_KEY_PASSWORD: Das Passwort für das Zertifikat.
CSC_LINK=C:\Zertifikat\mein-zertifikat.pfx
CSC_KEY_PASSWORD=IhrSicheresPasswort

# 2. macOS Code Signing (optional)
# APPLE_ID=Ihre Apple ID Email
# APPLE_ID_PASSWORD=App-spezifisches Passwort (nicht das normale Account-PW)
# APPLE_TEAM_ID=Ihre Team ID (aus dem Apple Developer Portal)
